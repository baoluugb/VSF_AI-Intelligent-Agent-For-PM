data/vault.db
data/chroma/
*.db
*.sqlite3

# ---- Generated agent outputs (regenerated by run_agent.sh) ----
output/

# ---- Build / packaging ----
build/
dist/
*.egg-info/

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.idea/
