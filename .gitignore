# ---- Secrets / environment ----
.env
.env.*
!.env.example

# ---- Python bytecode & caches ----
__pycache__/
*.py[cod]
*$py.class

# ---- Test / type / lint caches ----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Generated data stores (rebuilt by the ingestion pipeline) ----
