# Copy this file to `.env` and fill in your own values.  `.env` is gitignored —
# never commit real keys.
#
#   cp .env.example .env

# --- LLM provider (OpenAI-compatible) ---------------------------------------
# Required. Your API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model name. Any chat-completions model your key/endpoint supports.
OPENAI_MODEL=gpt-4o-mini

# Optional. Leave UNSET to use the default https://api.openai.com/v1.
# Set it only when targeting an OpenAI-compatible proxy, e.g. ckey.vn:
#   OPENAI_BASE_URL=https://ckey.vn/v1
# (An empty value would override the default with a blank URL — comment it out
#  rather than leaving it blank.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Report rendering -------------------------------------------------------
# Language of the daily report + risk explanations: "vi" (default) or "en".
REPORT_LANG=vi
# Optional: Jira base URL to make issue citations like [FLINK-40] clickable.
# Leave empty to disable links.
# JIRA_BASE_URL=https://your-org.atlassian.net

# --- MCP server (Week 5 §5.1) -----------------------------------------------
# Required by every MCP endpoint via the `X-API-Key` request header. The server
# fails closed (401) if this is unset. Generate a random value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=generate-a-random-token-here
